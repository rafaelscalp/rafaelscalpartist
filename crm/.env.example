# Copiar este archivo como .env y completar los valores

# Token secreto para verificar el webhook de Meta (puede ser cualquier palabra)
META_VERIFY_TOKEN=scalp_verify_2024

# Token de acceso de la página de Facebook (se obtiene en Meta for Developers)
META_PAGE_ACCESS_TOKEN=

# Puerto del servidor (Railway lo asigna automáticamente)
PORT=3001
